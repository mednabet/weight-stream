# ============================================
# Weight Stream — Configuration serveur
# ============================================
# Copiez ce fichier vers .env et modifiez les valeurs

# ── Base de données (MySQL) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=production_manager
DB_USER=prod_app
DB_PASSWORD=CHANGEZ_CE_MOT_DE_PASSE

# ── Serveur ──
PORT=3001
NODE_ENV=production

# ── CORS ──
# Liste des origines autorisées séparées par des virgules
# NE JAMAIS utiliser * en production
CORS_ORIGIN=https://votre-domaine.com

# ── Sécurité ──
# Clé secrète JWT (minimum 32 caractères, obligatoire en production)
# Générez avec : openssl rand -base64 64
JWT_SECRET=CHANGEZ_CETTE_CLE_SECRETE_MINIMUM_32_CARACTERES

# ── Options avancées ──
# DB_SSL=false
# DB_POOL_SIZE=10
# APP_CONFIG_PATH=/chemin/vers/app-config.json
